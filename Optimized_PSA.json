# HTTP方法提取函数  
get_http_method = func(request_data) {  
    lines = str.SplitAndTrim(request_data, "\r\n")  
    request_line = lines[0]  
    method = str.SplitAndTrim(request_line, " ")[0]  
    return method  
}  

# 通配符转正则表达式  
wildcard_to_regex = func(pattern) {  
    patternX = `\*`  
    newStr = `[a-zA-Z0-9-]*`  
    pattern = re.ReplaceAll(pattern, patternX, newStr)  
    return "^" + pattern + "$"  
}  

# 优化的主机匹配函数，支持精确的端口匹配  
host_matches_with_port = func(targetUrl, pattern) {  
    targetHost, targetPort, err = str.ParseStringToHostPort(targetUrl)  
    if err != nil {  
        return false  
    }  
      
    target = targetHost  
    if targetPort > 0 {  
        target = sprintf("%s:%d", targetHost, targetPort)  
    }  
      
    if str.Contains(pattern, "*") {  
        return str.MatchAllOfRegexp(targetHost, wildcard_to_regex(pattern))  
    } else if str.Contains(pattern, ":") {  
        return target == pattern  
    } else {  
        return targetHost == pattern  
    }  
}  

# 检查路径是否匹配模式  
path_matches = func(path, pattern) {  
    if str.Contains(pattern, "*") {  
        return str.MatchAllOfRegexp(path, wildcard_to_regex(pattern))  
    } else {  
        return str.HasPrefix(path, pattern)  
    }  
}  

