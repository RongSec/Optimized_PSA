# 全局变量  
passiveScanners = []  

# 初始化逻辑，使用按行分隔  
if passiveScanning != "" {  
    scannerList = str.ParseStringToLines(passiveScanning)  
    for scanner in scannerList {  
        scanner = str.TrimSpace(scanner)  
        if scanner != "" {  
            passiveScanners = append(passiveScanners, scanner)  
        }  
    }  
}  

# ========== 去重相关全局变量 ==========
var dedupMutex = sync.NewMutex()
var dedupCache = make(map[string]bool)
var dedupQueue = make([]string, 0)

# 计算请求包的指纹（根据用户选择的模式）
calc_fingerprint = func(reqBytes, mode) {
    if mode == "full" {
        return codec.Md5(reqBytes)
    } else if mode == "method_url" {
        # 解析请求行，获取方法 + 原始URL
        reqStr = string(reqBytes)
        lines = str.SplitAndTrim(reqStr, "\r\n")
        if len(lines) == 0 {
            return ""
        }
        requestLine = lines[0]
        parts = str.SplitAndTrim(requestLine, " ")
        if len(parts) < 2 {
            return ""
        }
        method = parts[0]
        rawUrl = parts[1]
        fingerprintStr = sprintf("%s %s", method, rawUrl)
        return codec.Md5(fingerprintStr)
    }
    return ""
}

# 检查并记录去重，返回true表示重复（已存在），false表示新请求需要发送
check_and_record = func(fingerprint) {
    if fingerprint == "" {
        return false   # 指纹无效，当作新请求
    }
    dedupMutex.Lock()
    defer dedupMutex.Unlock()
    
    # 检查是否已存在
    if dedupCache[fingerprint] {
        return true
    }
    
    # 记录新指纹
    dedupCache[fingerprint] = true
    dedupQueue = append(dedupQueue, fingerprint)
    
    # 超出缓存大小限制，淘汰最早的
    if len(dedupQueue) > dedupCacheSize {
        oldestFp = dedupQueue[0]
        delete(dedupCache, oldestFp)
        dedupQueue = dedupQueue[1:]
    }
    return false
}

# 发送到所有扫描器  
send_to_all_scanners = func(isHttps, req) {  
    if len(passiveScanners) == 0 {  
        return  
    }  
      
    for scanner in passiveScanners {  
        if scanner != "" {  
            poc.HTTP(req, poc.https(isHttps), poc.proxy(scanner), poc.timeout(5), poc.useMitmRule(useMITMRule))  
        }  
    }  
}  

mirrorHTTPFlow = func(isHttps /* bool */, url /* string */, req /* []byte */, rsp /* []byte */, body /* []byte */) {  
    method = get_http_method(string(req))  
  
    # 1. 检查HTTP方法黑名单  
    if len(blackmethodcli) != 0 {  
        for blackmethod in blackmethodcli {  
            if method == blackmethod {  
                return  
            }  
        }  
    }  
      
    if disableSuffixscli != "" {  
        disableSuffixs = str.ParseStringToLines(disableSuffixscli)  
        for disableSuffix in disableSuffixs {  
            if str.EndsWith(url, disableSuffix) {  
                return  
            }  
        }  
    }  
      
    # 解析URL获取路径  
    parsedUrl, err = str.ParseStringUrlToUrlInstance(url)  
    if err != nil {  
        return  
    }  
    path = parsedUrl.Path  
  
    # 3. 检查主机黑名单（使用优化的端口匹配）  
    if blacklistcli != "" {  
        blacklist = str.ParseStringToLines(blacklistcli)  
        for blackhost in blacklist {  
            if host_matches_with_port(url, blackhost) {  
                return  
            }  
        }  
    }  
      
    if blacklistpathcli != "" {  
        blacklistpaths = str.ParseStringToLines(blacklistpathcli)  
        for blackpath in blacklistpaths {  
            if path_matches(path, blackpath) {  
                return  
            }  
        }  
    }  
      
    hostWhitelisted = false  
    if whitelisthostcli != "" {  
        whitelist = str.ParseStringToLines(whitelisthostcli)  
        for whitehost in whitelist {  
            if host_matches_with_port(url, whitehost) {  
                hostWhitelisted = true  
                break  
            }  
        }  
          
        if !hostWhitelisted {  
            return  
        }  
    } else {  
        hostWhitelisted = true  
    }  
      
    pathWhitelisted = false  
    if whitelistpathcli != "" {  
        whitelistpaths = str.ParseStringToLines(whitelistpathcli)  
        for whitepath in whitelistpaths {  
            if path_matches(path, whitepath) {  
                pathWhitelisted = true  
                break  
            }  
        }  
          
        if !pathWhitelisted {  
            return  
        }  
    } else {  
        pathWhitelisted = true  
    }  
      
    if hostWhitelisted && pathWhitelisted {  
        # ========== 去重处理 ==========
        if dedupMode != "none" {
            # 直接使用返回值调用，避免中间变量
            if check_and_record(calc_fingerprint(req, dedupMode)) {
                return
            }
        }
        # 转发到所有扫描器
        send_to_all_scanners(isHttps, req)  
    }  
}